---
// Starlight 기본 Footer(이전/다음·최종수정·편집링크)에
// 글 페이지용 JSON-LD(Article/Breadcrumb)와 Giscus 댓글을 덧붙인다.
// (블로그 본문 렌더는 starlight-blog가 MarkdownContent override로 직접 처리하므로
//  여기서 본문을 감싸지 않는다 — starlight-blog의 MarkdownContent 경고 제거)
import Default from '@astrojs/starlight/components/Footer.astro';
import Giscus from './Giscus.astro';

const path = Astro.url.pathname.replace(/\/$/, '');
const segments = path.split('/').filter(Boolean);
// index(MOC) 페이지 제외: /knowledge/, /knowledge/os/ 등
// blog, til은 depth 2도 실제 글이므로 허용
const slug = Astro.locals.starlightRoute?.entry?.slug ?? '';
const is404 = slug === '404' || slug.endsWith('/404');
const isKnowledge = segments[0] === 'knowledge';
const isNavPage = segments.length <= 1 || (isKnowledge && segments.length <= 2);

// JSON-LD Structured Data
const entry = Astro.locals.starlightRoute?.entry;
const siteUrl = 'https://ycra-dev.github.io';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const title = entry?.data?.title ?? '';
const description = entry?.data?.description ?? '';
const created = entry?.data?.created;
const updated = entry?.data?.updated;

const isArticle = !isNavPage && !is404 && segments.length >= 2;

const articleJsonLd = isArticle ? JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	url: pageUrl,
	...(created && { datePublished: new Date(created).toISOString() }),
	...(updated && { dateModified: new Date(updated).toISOString() }),
	image: `${siteUrl}/og-image.png`,
	author: { '@type': 'Person', name: 'ycra' },
	publisher: { '@type': 'Organization', name: 'ycra.dev', url: siteUrl },
}) : null;

const breadcrumbItems = segments.map((seg, i) => ({
	'@type': 'ListItem',
	position: i + 1,
	name: i === segments.length - 1 ? title : seg.charAt(0).toUpperCase() + seg.slice(1),
	item: `${siteUrl}/${segments.slice(0, i + 1).join('/')}/`,
}));

const breadcrumbJsonLd = segments.length >= 1 && !is404 ? JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems,
}) : null;
---

{!isNavPage && !is404 && <Giscus />}
{articleJsonLd && <script type="application/ld+json" set:html={articleJsonLd} />}
{breadcrumbJsonLd && <script type="application/ld+json" set:html={breadcrumbJsonLd} />}
<Default><slot /></Default>
